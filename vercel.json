{
  "name": "federal-contracting-monitor",
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": [
    {
      "key": "NEXT_PUBLIC_SUPABASE_URL",
      "value": "https://scvvadyftbrgzpwngfff.supabase.co"
    },
    {
      "key": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
      "value": "@SUPABASE_ANON_KEY"
    },
    {
      "key": "NEXT_PUBLIC_SAM_API_KEY",
      "value": "@SAM_API_KEY"
    },
    {
      "key": "NEXT_PUBLIC_USASPENDING_API_BASE",
      "value": "https://api.usaspending.gov/api/v2"
    },
    {
      "key": "NODE_ENV",
      "value": "production"
    }
  ],
  "regions": [
    "iad1"
  ],
  "routes": [
    {
      "src": "/(.*)",
      "destination": "/$1"
    }
  ]
}
